# .env.example — copia este fichero como .env y rellena los valores
# cp .env.example .env

# ── LiveKit Server ─────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://tu-servidor.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── STT: Deepgram ──────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ── TTS: Cartesia ──────────────────────────────────────────────────────────────
CARTESIA_API_KEY=

# ── LLM: Groq (compatible OpenAI, modelo Llama 3.3 70B) ───────────────────────
GROQ_API_KEY=

# ── GLPI REST API ──────────────────────────────────────────────────────────────
GLPI_URL=https://tuglpi.empresa.com/apirest.php
GLPI_APP_TOKEN=
GLPI_USER=
GLPI_PASS=

# ── Logging: DEBUG, INFO, WARNING, ERROR ──────────────────────────────────────
LOG_LEVEL=INFO
