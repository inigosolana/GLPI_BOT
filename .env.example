# .env.example — copia este fichero como .env y rellena los valores
# cp .env.example .env

# LiveKit — Settings → Keys en tu proyecto LiveKit Cloud
LIVEKIT_URL=wss://NOMBREPROYECTO.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deepgram — console.deepgram.com → API Keys
DEEPGRAM_API_KEY=

# Cartesia — play.cartesia.ai → API Keys
CARTESIA_API_KEY=

# Groq — console.groq.com → API Keys
GROQ_API_KEY=

# GLPI — Configuración → General → API
GLPI_URL=https://tuglpi.empresa.com/apirest.php
GLPI_APP_TOKEN=
GLPI_USER=
GLPI_PASS=

LOG_LEVEL=INFO
